{
  "name": "AppStats",
  "type": "object",
  "properties": {
    "key": {
      "type": "string",
      "description": "Stat identifier, e.g. 'user_count'"
    },
    "value": {
      "type": "number",
      "default": 0,
      "description": "The numeric value of the stat"
    }
  },
  "required": [
    "key"
  ]
}